@page "/instances/{InstanceId}"
@using IgniteWebUI.Models.Contexts
@using IgniteWebUI.Components.Dashboard
@using MudBlazor.Charts
@layout InstanceLayout
@implements IDisposable

@inject InstanceManager InstanceManager
@inject DashboardLayoutService LayoutService
<PageTitle>Instance Overview</PageTitle>

@if (_instance is null)
{
    <MudAlert Severity="Severity.Error">Instance not found</MudAlert>
}
else
{
    <!-- Widget Grid for Instance Overview Page -->
    <WidgetGrid LayoutService="LayoutService" LayoutId="@_layoutId" Name="@(_instance.Name + " Dashboard")" />
}

    @code {
    [Parameter] public string InstanceId { get; set; } = default!;

    [CascadingParameter]
    public InstanceContext Context { get; set; } = default!;

    private TorchInstanceBase? _instance;
    private string _layoutId = string.Empty;


    // -- Lifecycle -------------------------------------------------------
    protected override void OnInitialized()
    {
        _instance = InstanceManager.GetInstanceByID(Context.InstanceId);
        _layoutId = $"instance-overview-{Context.InstanceId}";
        LayoutService.SwitchLayout(_layoutId);

        InstanceManager.OnChange += OnInstanceUpdated;
    }

    private void OnInstanceUpdated(string updatedId)
    {
        if (_instance is null || updatedId != _instance.InstanceID)
            return;

        InvokeAsync(() =>
        {
            _instance = InstanceManager.GetInstanceByID(Context.InstanceId);

            StateHasChanged();
        });
    }


    public void Dispose()
    {
        InstanceManager.OnChange -= OnInstanceUpdated;
    }
}
