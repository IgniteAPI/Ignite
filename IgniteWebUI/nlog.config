<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off"
      internalLogFile="Logs/internal-nlog.txt">

  <variable name="logStamp" value="${time} ${pad:padding=-8:inner=[${level:uppercase=true}]}" />
  <variable name="logContent" value="${message} ${exception:format=ToString}" />

  <targets async="true">
    <!-- WebUI application log -->
    <target xsi:type="File" name="webui"
            layout="${var:logStamp} ${logger:shortName=true}: ${var:logContent}"
            fileName="Logs/webui-${shortdate}.log" />

    <!-- Instance forwarded logs -->
    <target xsi:type="File" name="instances"
            layout="${var:logStamp} ${message}"
            fileName="Logs/instances-${shortdate}.log" />

    <!-- Chat forwarded logs -->
    <target xsi:type="File" name="chat"
            layout="${var:logStamp} ${message}"
            fileName="Logs/chat-${shortdate}.log" />

    <target xsi:type="ColoredConsole" name="console"
            layout="${var:logStamp} ${logger:shortName=true}: ${var:logContent}" />

    <!-- In-browser log viewer -->
    <target xsi:type="LogViewer" name="logviewer" />
  </targets>

  <rules>
    <!-- Instance log entries forwarded from game servers -->
    <logger name="IgniteWebUI.Services.InstanceServices.InstanceLogService" minlevel="Trace" writeTo="instances" final="true" />

    <!-- Chat entries forwarded from game servers -->
    <logger name="IgniteWebUI.Services.InstanceServices.InstanceChatService" minlevel="Trace" writeTo="chat" final="true" />

    <!-- Suppress noisy ASP.NET Core infrastructure logs to Debug -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- All other WebUI application logs -->
    <logger name="*" minlevel="Trace" writeTo="console,webui,logviewer" />
  </rules>

</nlog>
