@page "/Settings"
@using MudBlazor.Utilities
@using Torch2WebUI.Services
@using Torch2WebUI.Configs
@inject ThemeService ThemeService
@inject Torch2WebUICfg Config
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Administration Settings</MudText>

<MudTabs Elevation="2">
    <!-- Web UI Settings Tab -->
    <MudTabPanel Text="Web UI">
        <MudStack Spacing="4" Class="pa-4">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" GutterBottom="true">Panel Configuration</MudText>
                <MudStack Spacing="3">
                    <MudTextField Label="Panel Name" 
                                   @bind-Value="Config.PanelName"
                                   Variant="Variant.Outlined"
                                   HelperText="Name of the Web UI Panel"
                                   FullWidth="true" />

                    <MudNumericField Label="Web UI Port"
                                      @bind-Value="Config.Port"
                                      Variant="Variant.Outlined"
                                      HelperText="Web UI Port (Note: requires restart)"
                                      FullWidth="true" />
                </MudStack>
            </MudPaper>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings">
                Save Settings
            </MudButton>
        </MudStack>
    </MudTabPanel>

    <!-- Logging Settings Tab -->
    <MudTabPanel Text="Logging">
        <MudStack Spacing="4" Class="pa-4">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" GutterBottom="true">Log Configuration</MudText>
                <MudStack Spacing="3">
                    <MudTextField Label="Log Directory"
                                   @bind-Value="Config.Logging.LogDirectory"
                                   Variant="Variant.Outlined"
                                   HelperText="Log file directory path"
                                   FullWidth="true" />

                    <MudNumericField Label="Max Log Age (Days)"
                                      @bind-Value="Config.Logging.MaxLogAgeDays"
                                      Variant="Variant.Outlined"
                                      HelperText="Maximum age of log files in days before deletion"
                                      FullWidth="true" />

                    <MudSelect T="string" Label="Log Level" 
                               @bind-Value="Config.Logging.LogLevel"
                               Variant="Variant.Outlined"
                               HelperText="Log level (Trace, Debug, Information, Warning, Error, Critical)"
                               FullWidth="true">
                        <MudSelectItem Value="@("Trace")">Trace</MudSelectItem>
                        <MudSelectItem Value="@("Debug")">Debug</MudSelectItem>
                        <MudSelectItem Value="@("Information")">Information</MudSelectItem>
                        <MudSelectItem Value="@("Warning")">Warning</MudSelectItem>
                        <MudSelectItem Value="@("Error")">Error</MudSelectItem>
                        <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                    </MudSelect>

                    <MudSwitch T="bool" @bind-Checked="Config.Logging.EnableInstanceLogging"
                               Label="Log Instances to Console"
                               Color="Color.Primary" />

                    <MudNumericField Label="Instance Log Max Entries"
                                      @bind-Value="Config.Logging.InstanceLogViewerMaxEntries"
                                      Variant="Variant.Outlined"
                                      HelperText="Maximum number of log entries to keep for each instance in memory"
                                      FullWidth="true" />

                    <MudNumericField Label="Instance Chat Max Entries"
                                      @bind-Value="Config.Logging.InstanceChatViewerMaxEntries"
                                      Variant="Variant.Outlined"
                                      HelperText="Maximum number of chat entries to keep for each instance in memory"
                                      FullWidth="true" />
                </MudStack>
            </MudPaper>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings">
                Save Settings
            </MudButton>
        </MudStack>
    </MudTabPanel>

    <!-- Theme Settings Tab -->
    <MudTabPanel Text="Theme">
        <MudStack Spacing="4" Class="pa-4">
            <!-- Dark Palette Settings -->
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" GutterBottom="true">Dark Theme Palette</MudText>
                <MudStack Spacing="3">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">Primary & Surface</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Primary;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Primary" Label="Primary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Surface;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Surface" Label="Surface" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Background & UI</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Background;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Background" Label="Background" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.AppbarBackground;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.AppbarBackground" Label="Appbar BG" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.DrawerBackground;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.DrawerBackground" Label="Drawer BG" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.BackgroundGray;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.BackgroundGray" Label="Background Gray" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Text Colors</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.TextPrimary;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.TextPrimary" Label="Text Primary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.TextSecondary;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.TextSecondary" Label="Text Secondary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.TextDisabled;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.TextDisabled" Label="Text Disabled" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.AppbarText;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.AppbarText" Label="Appbar Text" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Status Colors</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Success;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Success" Label="Success" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Warning;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Warning" Label="Warning" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Error;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Error" Label="Error" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_darkPaletteEdit.Info;"></div>
                                <MudColorPicker @bind-Text="_darkPaletteEdit.Info" Label="Info" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            <!-- Light Palette Settings -->
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" GutterBottom="true">Light Theme Palette</MudText>
                <MudStack Spacing="3">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">Primary & Surface</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Primary;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Primary" Label="Primary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Surface;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Surface" Label="Surface" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Background & UI</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Background;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Background" Label="Background" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.AppbarBackground;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.AppbarBackground" Label="Appbar BG" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.DrawerBackground;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.DrawerBackground" Label="Drawer BG" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.BackgroundGray;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.BackgroundGray" Label="Background Gray" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Text Colors</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.TextPrimary;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.TextPrimary" Label="Text Primary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.TextSecondary;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.TextSecondary" Label="Text Secondary" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.TextDisabled;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.TextDisabled" Label="Text Disabled" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.AppbarText;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.AppbarText" Label="Appbar Text" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.body2" Class="font-weight-bold">Status Colors</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Success;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Success" Label="Success" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Warning;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Warning" Label="Warning" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Error;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Error" Label="Error" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <div style="width: 50px; height: 50px; border-radius: 4px; border: 2px solid #555; background-color: @_lightPaletteEdit.Info;"></div>
                                <MudColorPicker @bind-Text="_lightPaletteEdit.Info" Label="Info" Variant="Variant.Outlined" Style="flex: 1;" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyTheme">
                    Apply Theme
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetTheme">
                    Reset to Default
                </MudButton>
            </MudStack>
        </MudStack>
    </MudTabPanel>
</MudTabs>

@code {
    private DarkPaletteConfig _darkPaletteEdit = new();
    private LightPaletteConfig _lightPaletteEdit = new();

    protected override void OnInitialized()
    {
        _darkPaletteEdit = new DarkPaletteConfig()
        {
            Primary = Config.DarkPalette.Primary ?? "#e1824bff",
            Surface = Config.DarkPalette.Surface ?? "#1e1e2d",
            Background = Config.DarkPalette.Background ?? "#1e1e28ff",
            BackgroundGray = Config.DarkPalette.BackgroundGray ?? "#151521",
            AppbarText = Config.DarkPalette.AppbarText ?? "#92929f",
            AppbarBackground = Config.DarkPalette.AppbarBackground ?? "rgba(26,26,39,0.8)",
            DrawerBackground = Config.DarkPalette.DrawerBackground ?? "#1a1a27",
            ActionDefault = Config.DarkPalette.ActionDefault ?? "#74718e",
            ActionDisabled = Config.DarkPalette.ActionDisabled ?? "#9999994d",
            ActionDisabledBackground = Config.DarkPalette.ActionDisabledBackground ?? "#605f6d4d",
            TextPrimary = Config.DarkPalette.TextPrimary ?? "#b2b0bf",
            TextSecondary = Config.DarkPalette.TextSecondary ?? "#92929f",
            TextDisabled = Config.DarkPalette.TextDisabled ?? "#ffffff33",
            DrawerIcon = Config.DarkPalette.DrawerIcon ?? "#92929f",
            DrawerText = Config.DarkPalette.DrawerText ?? "#92929f",
            GrayLight = Config.DarkPalette.GrayLight ?? "#2a2833",
            GrayLighter = Config.DarkPalette.GrayLighter ?? "#1e1e2d",
            Info = Config.DarkPalette.Info ?? "#4a86ff",
            Success = Config.DarkPalette.Success ?? "#3dcb6c",
            Warning = Config.DarkPalette.Warning ?? "#ffb545",
            Error = Config.DarkPalette.Error ?? "#ff3f5f",
            LinesDefault = Config.DarkPalette.LinesDefault ?? "#33323e",
            TableLines = Config.DarkPalette.TableLines ?? "#33323e",
            Divider = Config.DarkPalette.Divider ?? "#292838",
            OverlayLight = Config.DarkPalette.OverlayLight ?? "#1e1e2d80"
        };
        _lightPaletteEdit = new LightPaletteConfig()
        {
            Black = Config.LightPalette.Black ?? "#110e2d",
            Primary = Config.LightPalette.Primary ?? "#e1824bff",
            Surface = Config.LightPalette.Surface ?? "#f5f5f5",
            Background = Config.LightPalette.Background ?? "#fafafa",
            BackgroundGray = Config.LightPalette.BackgroundGray ?? "#eeeeee",
            AppbarText = Config.LightPalette.AppbarText ?? "#424242",
            AppbarBackground = Config.LightPalette.AppbarBackground ?? "rgba(255,255,255,0.8)",
            DrawerBackground = Config.LightPalette.DrawerBackground ?? "#ffffff",
            ActionDefault = Config.LightPalette.ActionDefault ?? "#757575",
            ActionDisabled = Config.LightPalette.ActionDisabled ?? "#bdbdbd4d",
            ActionDisabledBackground = Config.LightPalette.ActionDisabledBackground ?? "#f5f5f54d",
            TextPrimary = Config.LightPalette.TextPrimary ?? "#212121",
            TextSecondary = Config.LightPalette.TextSecondary ?? "#757575",
            TextDisabled = Config.LightPalette.TextDisabled ?? "#bdbdbd",
            DrawerIcon = Config.LightPalette.DrawerIcon ?? "#757575",
            DrawerText = Config.LightPalette.DrawerText ?? "#757575",
            GrayLight = Config.LightPalette.GrayLight ?? "#e8e8e8",
            GrayLighter = Config.LightPalette.GrayLighter ?? "#f9f9f9",
            Info = Config.LightPalette.Info ?? "#1976d2",
            Success = Config.LightPalette.Success ?? "#388e3c",
            Warning = Config.LightPalette.Warning ?? "#f57c00",
            Error = Config.LightPalette.Error ?? "#d32f2f",
            LinesDefault = Config.LightPalette.LinesDefault ?? "#e0e0e0",
            TableLines = Config.LightPalette.TableLines ?? "#e0e0e0",
            Divider = Config.LightPalette.Divider ?? "#e0e0e0",
            OverlayLight = Config.LightPalette.OverlayLight ?? "#f5f5f580"
        };
    }

    private void ApplyTheme()
    {
        try
        {
            Config.DarkPalette = _darkPaletteEdit;
            Config.LightPalette = _lightPaletteEdit;
            ThemeService.UpdateTheme();
            Snackbar.Add("Theme applied successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to apply theme: {ex.Message}", Severity.Error);
        }
    }

    private void ResetTheme()
    {
        _darkPaletteEdit = new DarkPaletteConfig();
        _lightPaletteEdit = new LightPaletteConfig();
        Config.DarkPalette = new DarkPaletteConfig();
        Config.LightPalette = new LightPaletteConfig();
        ThemeService.UpdateTheme();
        Snackbar.Add("Theme reset to default", Severity.Info);
    }

    private void SaveSettings()
    {
        try
        {
            Config.Save();
            Snackbar.Add("Settings saved successfully", Severity.Success);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save settings: {ex.Message}", Severity.Error);
        }
    }
}
